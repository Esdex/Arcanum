<?xml version="1.0" encoding="utf-8"?>
<!-- Auto-backup rules for API < 31. Excludes all sensitive data. -->
<full-backup-content>
    <!-- PIN hashes and panic PIN stored in EncryptedSharedPreferences -->
    <exclude domain="sharedpref" path="arcanum_pin_prefs.xml"/>
    <!-- Biometric-wrapped container passwords stored in EncryptedSharedPreferences -->
    <exclude domain="sharedpref" path="arcanum_bio_prefs.xml"/>

    <!-- Room database: container registry, calculator history -->
    <exclude domain="database" path="arcanum.db"/>
    <exclude domain="database" path="arcanum.db-shm"/>
    <exclude domain="database" path="arcanum.db-wal"/>

    <!-- DataStore preference files -->
    <exclude domain="file" path="datastore/app_preferences.preferences_pb"/>
    <exclude domain="file" path="datastore/panic_settings.preferences_pb"/>
    <exclude domain="file" path="datastore/vault_display_prefs.preferences_pb"/>

    <!-- Temporary decrypted cache -->
    <exclude domain="file" path="arcanum_temp/"/>
</full-backup-content>
