<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Storage -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <!-- Biometrics -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />

    <!-- Services -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- USB host (for USB container support — future) -->
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.flash" android:required="false" />

    <application
        android:name=".ArcanumApp"
        android:enableOnBackInvokedCallback="true"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Arcanum">

        <service
            android:name=".arcanum.containers.service.ContainerCreationService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".arcanum.containers.service.ChangePasswordService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".arcanum.containers.service.ChangeKeyfileService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".arcanum.containers.service.ExpandVolumeService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".arcanum.backup.BackupService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Disable WorkManager auto-init so HiltWorkerFactory can be injected first -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.Arcanum"
            android:windowSoftInputMode="adjustResize"/>

        <!-- Default launcher entry — shown when disguise is OFF -->
        <activity-alias
            android:name=".MainActivityArcanum"
            android:targetActivity=".MainActivity"
            android:label="@string/app_name"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Calculator disguise entry — shown when disguise is ON -->
        <activity-alias
            android:name=".MainActivityCalculator"
            android:targetActivity=".MainActivity"
            android:label="@string/app_name_calculator"
            android:icon="@mipmap/ic_launcher_calculator"
            android:roundIcon="@mipmap/ic_launcher_calculator_round"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivitySystem"
            android:targetActivity=".MainActivity"
            android:label="@string/app_name_system"
            android:icon="@mipmap/ic_launcher_system"
            android:roundIcon="@mipmap/ic_launcher_system_round"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityMail"
            android:targetActivity=".MainActivity"
            android:label="@string/app_name_mail"
            android:icon="@mipmap/ic_launcher_mail"
            android:roundIcon="@mipmap/ic_launcher_mail_round"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityFlashlight"
            android:targetActivity=".MainActivity"
            android:label="@string/app_name_flashlight"
            android:icon="@mipmap/ic_launcher_flashlight"
            android:roundIcon="@mipmap/ic_launcher_flashlight_round"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityTools"
            android:targetActivity=".MainActivity"
            android:label="@string/app_name_tools"
            android:icon="@mipmap/ic_launcher_tools"
            android:roundIcon="@mipmap/ic_launcher_tools_round"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivitySystemTools"
            android:targetActivity=".MainActivity"
            android:label="@string/app_name_system_tools"
            android:icon="@mipmap/ic_launcher_system_tools"
            android:roundIcon="@mipmap/ic_launcher_system_tools_round"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityTaskManager"
            android:targetActivity=".MainActivity"
            android:label="@string/app_name_task_manager"
            android:icon="@mipmap/ic_launcher_task_manager"
            android:roundIcon="@mipmap/ic_launcher_task_manager_round"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityTimer"
            android:targetActivity=".MainActivity"
            android:label="@string/app_name_timer"
            android:icon="@mipmap/ic_launcher_timer"
            android:roundIcon="@mipmap/ic_launcher_timer_round"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".MainActivityStopwatch"
            android:targetActivity=".MainActivity"
            android:label="@string/app_name_stopwatch"
            android:icon="@mipmap/ic_launcher_stopwatch"
            android:roundIcon="@mipmap/ic_launcher_stopwatch_round"
            android:enabled="false"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

    </application>

</manifest>
